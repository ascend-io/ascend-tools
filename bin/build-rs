#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "${BASH_SOURCE[0]}")/.."

echo "Building ascend-ops-core..."
cargo build --manifest-path src/ascend_ops/ascend-ops-core/Cargo.toml "$@"

echo "Building ascend-ops-cli..."
cargo build --manifest-path src/ascend_ops/ascend-ops-cli/Cargo.toml "$@"

echo "Rust build complete!"
